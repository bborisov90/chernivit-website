---
const {
  eyebrow = "",
  title,
  text = "",
  image = "/images/village.jpg",
} = Astro.props;
---

<section class="page-hero" style={`--hero-image: url("${image}")`}>
  <div class="page-hero__content">
    {eyebrow && <p class="page-hero__eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {text && <p>{text}</p>}
  </div>
</section>