---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";

const photos = [
  "/images/gallery/photo-1.jpg",
  "/images/gallery/photo-2.jpg",
  "/images/gallery/photo-3.jpg",
  "/images/gallery/photo-4.jpg",
  "/images/gallery/photo-5.jpg",
  "/images/gallery/photo-6.jpg",
  "/images/gallery/photo-7.jpg",
  "/images/gallery/photo-8.jpg",
  "/images/gallery/photo-9.jpg",
  "/images/gallery/photo-10.jpg",
  "/images/gallery/photo-11.jpg",
  "/images/gallery/photo-12.jpg",];
---

<Layout title="Галерия | Черни Вит" description="Снимки от Черни Вит.">
  <PageHero
    eyebrow="Снимки от селото"
    title="Галерия"
    text="Първа обща галерия със снимки от Черни Вит. С времето тук ще добавяме още кадри от селото, природата, махалите и забележителностите."
    image="/images/gallery/photo-1.jpg"
  />

  <main class="gallery-page">
    <section class="photo-grid">
      {photos.map((photo, index) => (
        <figure>
          <img src={photo} alt={`Снимка от Черни Вит ${index + 1}`} />
        </figure>
      ))}
    </section>

    <section class="archive-card">
      <h2>Събираме още снимки</h2>
      <p>
        Ако пазите снимки от Черни Вит – стари или нови, от селото, махалите,
        училището, реката, забележителностите или събития – можете да помогнете
        за създаването на дигитален архив.
      </p>
      <a href="/kontakti/">Изпрати снимки</a>
    </section>
  </main>
</Layout>

<style>
  .gallery-page {
    width: var(--container);
    margin: 0 auto;
    padding-bottom: 70px;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .photo-grid figure {
    margin: 0;
    overflow: hidden;
    border-radius: 24px;
    background: var(--color-card);
    box-shadow: 0 16px 40px rgba(40, 32, 20, 0.08);
  }

  .photo-grid img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    transition: transform 0.25s ease;
  }

  .photo-grid figure:hover img {
    transform: scale(1.04);
  }

  .archive-card {
    margin-top: 40px;
    padding: clamp(28px, 5vw, 52px);
    border-radius: 28px;
    background: var(--color-green);
    color: white;
    text-align: center;
  }

  .archive-card h2 {
    margin-top: 0;
    color: white;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .archive-card p {
    max-width: 760px;
    margin: 0 auto;
    color: rgba(255, 250, 240, 0.85);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .archive-card a {
    display: inline-block;
    margin-top: 22px;
    padding: 13px 22px;
    border-radius: 999px;
    background: var(--color-gold);
    color: var(--color-green);
    text-decoration: none;
    font-family: Arial, sans-serif;
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }

    .photo-grid img {
      height: 240px;
    }
  }
</style>