---
import Layout from "../layouts/Layout.astro";

const cards = [
  {
    href: "/za-cherni-vit/",
    icon: "🌿",
    title: "За Черни Вит",
    text: "Научи повече за селото, природата и духа на Тетевенския Балкан.",
  },
  {
    href: "/istoria/",
    icon: "📜",
    title: "История",
    text: "Разгледай миналото, старите следи и паметта на селото.",
  },
  {
    href: "/zabelezhitelnosti/",
    icon: "⛰️",
    title: "Забележителности",
    text: "Открий природни, исторически и културни места около Черни Вит.",
  },
];
---

<Layout>
  <main class="home-page">
    <section class="home-hero">
      <div class="home-hero-content">
        <p class="eyebrow">Между Балкана, реката и традициите</p>

        <h1>Черни Вит</h1>

        <p>
          Живописно село в сърцето на Тетевенския Балкан, известно със своята
          природа, история, махали и уникалното зелено сирене.
        </p>

        <div class="hero-actions">
          <a href="/za-cherni-vit/" class="btn primary">
            Разгледай селото
          </a>

          <a href="/galeria/" class="btn secondary">
            Галерия
          </a>
        </div>
      </div>
    </section>

    <section class="intro-section">
      <h2>Добре дошли в Черни Вит</h2>

      <p>
        Разположено сред красивата природа на Централна Стара планина,
        село Черни Вит съчетава богата история, традиции и впечатляващи
        природни гледки. Тук реката, планината и местният дух създават
        неповторима атмосфера през всеки сезон.
      </p>
    </section>

    <section class="home-cards">
      {
        cards.map((card) => (
          <a href={card.href} class="home-card">
            <span>{card.icon}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </a>
        ))
      }
    </section>

    <section class="feature-section">
      <div>
        <p class="eyebrow dark">Уникална традиция</p>

        <h2>Зеленото сирене</h2>

        <p>
          Един от символите на Черни Вит е зеленото сирене —
          рядък местен продукт, който се произвежда по традиционна технология
          и е известен далеч извън пределите на България.
        </p>

        <a href="/zeleno-sirene/" class="text-link">
          Научи повече →
        </a>
      </div>

      <div class="feature-image">
        <img src="/images/cheese.jpg" alt="Зелено сирене" />
      </div>
    </section>

    <section class="gallery-preview">
      <div class="section-heading">
        <h2>Галерия</h2>

        <a href="/galeria/">
          Виж всички снимки →
        </a>
      </div>

      <div class="preview-grid">
        <img src="/images/village.jpg" alt="Черни Вит" />
        <img src="/images/winter.jpg" alt="Зимен Черни Вит" />
        <img src="/images/river.jpg" alt="Река Черни Вит" />
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-page {
    width: 100%;
    margin: 0;
    padding: 0 0 64px;
  }

  .home-hero {
    min-height: 100vh;
    margin-top: -90px;

    padding:
      160px
      max(32px, calc((100vw - 1120px) / 2))
      100px;

    display: flex;
    align-items: center;

    background:
      linear-gradient(
        rgba(15, 22, 16, 0.35),
        rgba(15, 22, 16, 0.65)
      ),
      url("/images/hero.jpg") center / cover;

    color: white;
  }

  .home-hero-content {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .9rem;
  }

  .dark {
    color: #6d7b4f;
  }

  .home-hero h1 {
    margin: 0 0 20px;
    font-size: clamp(4rem, 10vw, 7rem);
    line-height: .9;
  }

  .home-hero p {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .btn {
    padding: 14px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }

  .btn.primary {
    background: #fffaf0;
    color: #2f4a35;
  }

  .btn.secondary {
    border: 1px solid rgba(255,255,255,.5);
    color: white;
  }

  .intro-section,
  .feature-section,
  .gallery-preview,
  .home-cards {
    width: min(1120px, calc(100% - 32px));
    margin-left: auto;
    margin-right: auto;
  }

  .intro-section,
  .feature-section,
  .gallery-preview {
    background: #fffaf0;
    border-radius: 24px;
    padding: clamp(28px, 4vw, 44px);
    margin-top: 28px;
    border: 1px solid rgba(74,57,35,.12);
    box-shadow: 0 16px 40px rgba(40,32,20,.08);
  }

  .intro-section h2,
  .feature-section h2,
  .gallery-preview h2 {
    margin-top: 0;
    color: #2f4a35;
  }

  .intro-section p,
  .feature-section p {
    line-height: 1.8;
  }

  .home-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 28px;
  }

  .home-card {
    background: #fffaf0;
    border-radius: 24px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(74,57,35,.12);
    box-shadow: 0 16px 40px rgba(40,32,20,.08);
  }

  .home-card span {
    font-size: 2rem;
  }

  .home-card h3 {
    color: #2f4a35;
  }

  .feature-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: center;
  }

  .feature-image img {
    width: 100%;
    display: block;
    border-radius: 20px;
  }

  .text-link {
    text-decoration: none;
    color: #2f4a35;
    font-weight: 700;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .section-heading a {
    color: #2f4a35;
    text-decoration: none;
    font-weight: 700;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 18px;
  }

  .preview-grid img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    border-radius: 18px;
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: 90vh;
      margin-top: -86px;
      padding: 130px 24px 80px;
    }

    .home-cards,
    .feature-section,
    .preview-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .home-hero h1 {
      font-size: 4rem;
    }
  }
</style>