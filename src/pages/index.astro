---
import Layout from "../layouts/Layout.astro";

const cards = [
  {
    href: "/za-cherni-vit/",
    icon: "🌿",
    title: "За Черни Вит",
    text: "Научи повече за селото, природата и духа на Тетевенския Балкан.",
  },
  {
    href: "/istoria/",
    icon: "📜",
    title: "История",
    text: "Разгледай миналото, старите следи и паметта на селото.",
  },
  {
    href: "/zabelezhitelnosti/",
    icon: "⛰️",
    title: "Забележителности",
    text: "Открий природни, исторически и културни места около Черни Вит.",
  },
];
---

<Layout>
  <main class="home-page">
    <section class="home-hero">
      <div class="home-hero-content">
        <p class="eyebrow">Между Балкана, реката и традициите</p>
        <h1>Черни Вит</h1>
        <p>
          Живописно село в Тетевенския Балкан, известно със своята природа,
          махали, история и уникалното зелено сирене.
        </p>

        <div class="hero-actions">
          <a href="/za-cherni-vit/" class="btn primary">Разгледай селото</a>
          <a href="/galeria/" class="btn secondary">Виж галерията</a>
        </div>
      </div>
    </section>

    <section class="intro-section">
      <h2>Добре дошли в Черни Вит</h2>
      <p>
        Черни Вит е място, където планината, реката и местните традиции
        създават неповторима атмосфера. Селото пази спомена за миналото,
        красотата на природата и живия дух на хората.
      </p>
    </section>

    <section class="home-cards">
      {
        cards.map((card) => (
          <a href={card.href} class="home-card">
            <span>{card.icon}</span>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </a>
        ))
      }
    </section>

    <section class="feature-section">
      <div class="feature-text">
        <p class="eyebrow">Уникална традиция</p>
        <h2>Зеленото сирене</h2>
        <p>
          Един от символите на Черни Вит е зеленото сирене — рядък местен
          продукт, свързан със стария овчарски бит и естественото зреене.
        </p>
        <a href="/zeleno-sirene/" class="text-link">Научи повече →</a>
      </div>

      <div class="feature-image">
        <img src="/images/cheese.jpg" alt="Зелено сирене от Черни Вит" />
      </div>
    </section>

    <section class="gallery-preview">
      <div class="section-heading">
        <h2>Галерия</h2>
        <a href="/galeria/">Виж всички снимки →</a>
      </div>

      <div class="preview-grid">
        <img src="/images/village.jpg" alt="Черни Вит" />
        <img src="/images/winter.jpg" alt="Зимен Черни Вит" />
        <img src="/images/river.jpg" alt="Река Черни Вит" />
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 64px;
  }

  .home-hero {
    min-height: 560px;
    border-radius: 32px;
    padding: clamp(40px, 8vw, 90px);
    display: flex;
    align-items: center;
    background:
      linear-gradient(rgba(23,38,29,.52), rgba(23,38,29,.72)),
      url("/images/village.jpg") center / cover;
    color: white;
    box-shadow: 0 24px 60px rgba(40,32,20,.16);
  }

  .home-hero-content {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .9rem;
  }

  .home-hero h1 {
    margin: 0 0 16px;
    font-size: clamp(3rem, 9vw, 6.5rem);
    line-height: .95;
  }

  .home-hero p {
    font-size: clamp(1.08rem, 2vw, 1.4rem);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .btn {
    display: inline-block;
    padding: 13px 20px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }

  .btn.primary {
    background: #fffaf0;
    color: #2f4a35;
  }

  .btn.secondary {
    color: white;
    border: 1px solid rgba(255,255,255,.55);
  }

  .intro-section,
  .feature-section,
  .gallery-preview {
    margin-top: 28px;
    background: #fffaf0;
    border-radius: 24px;
    padding: clamp(26px, 4vw, 44px);
    border: 1px solid rgba(74,57,35,.12);
    box-shadow: 0 16px 40px rgba(40,32,20,.08);
  }

  .intro-section h2,
  .feature-section h2,
  .gallery-preview h2 {
    color: #2f4a35;
    margin-top: 0;
  }

  .intro-section p,
  .feature-section p {
    line-height: 1.8;
    font-size: 1.08rem;
  }

  .home-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 28px;
  }

  .home-card {
    background: #fffaf0;
    border-radius: 24px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(74,57,35,.12);
    box-shadow: 0 16px 40px rgba(40,32,20,.08);
  }

  .home-card span {
    font-size: 2rem;
  }

  .home-card h3 {
    color: #2f4a35;
    margin-bottom: 8px;
  }

  .home-card p {
    line-height: 1.6;
  }

  .feature-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: center;
  }

  .feature-image img {
    width: 100%;
    border-radius: 20px;
    display: block;
  }

  .text-link {
    color: #2f4a35;
    font-weight: 700;
    text-decoration: none;
  }

  .section-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .section-heading a {
    color: #2f4a35;
    font-weight: 700;
    text-decoration: none;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 18px;
  }

  .preview-grid img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 18px;
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: 460px;
      border-radius: 24px;
    }

    .home-cards,
    .feature-section,
    .preview-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>