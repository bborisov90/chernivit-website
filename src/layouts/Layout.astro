---
const navItems = [
  { href: "/", label: "Начало" },
  { href: "/za-cherni-vit/", label: "За Черни Вит" },
  { href: "/mahali/", label: "Махали" },
  { href: "/zabelezhitelnosti/", label: "Забележителности" },
  { href: "/zeleno-sirene/", label: "Зелено сирене" },
  { href: "/uchilishte/", label: "Училище" },
  { href: "/galeria/", label: "Галерия" },
  { href: "/novini/", label: "Новини" },
  { href: "/kontakti/", label: "Контакти" },
];
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Черни Вит</title>
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="site-logo">Черни Вит</a>

      <input type="checkbox" id="nav-toggle" class="nav-toggle" />

      <label for="nav-toggle" class="nav-button" aria-label="Отвори меню">
        <span></span>
        <span></span>
        <span></span>
      </label>

      <nav class="site-nav" aria-label="Основно меню">
        {
          navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
      </nav>
    </header>

    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    min-height: 100%;
    font-family: Georgia, "Times New Roman", serif;
    background: #f7f3ea;
    color: #2e2a24;
  }

  * {
    box-sizing: border-box;
  }

  .site-header {
    width: 100%;
    min-height: 86px;
    padding: 0 7vw;
    background: #10291d;
    color: #fffaf0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    position: sticky;
    top: 0;
    z-index: 999;
    box-shadow: 0 10px 30px rgba(16, 41, 29, 0.22);
  }

  .site-logo {
    color: #fffaf0;
    text-decoration: none;
    font-size: clamp(1.35rem, 2.5vw, 1.8rem);
    font-weight: 700;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 18px;
    flex-wrap: wrap;
  }

  .site-nav a {
    color: rgba(255, 250, 240, 0.9);
    text-decoration: none;
    font-family: Arial, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .site-nav a:hover {
    color: #e1b24d;
  }

  .nav-toggle,
  .nav-button {
    display: none;
  }

  @media (max-width: 900px) {
    .site-header {
      min-height: 82px;
      padding: 0 28px;
    }

    .nav-button {
      width: 54px;
      height: 54px;
      border: 1px solid rgba(255, 250, 240, 0.25);
      border-radius: 999px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      cursor: pointer;
    }

    .nav-button span {
      display: block;
      width: 24px;
      height: 3px;
      border-radius: 999px;
      background: #fffaf0;
      transition: 0.2s ease;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 82px;
      left: 0;
      right: 0;
      padding: 22px 28px 28px;
      background: #10291d;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 0 22px 48px rgba(16, 41, 29, 0.35);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      max-height: calc(100vh - 82px);
      overflow-y: auto;
    }

    .site-nav a {
      width: 100%;
      padding: 15px 0;
      color: #fffaf0;
      font-family: Arial, sans-serif;
      font-size: 1.15rem;
      font-weight: 500;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .site-nav a:last-child {
      border-bottom: 0;
    }

    .nav-toggle:checked ~ .site-nav {
      display: flex;
    }

    .nav-toggle:checked + .nav-button span:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .nav-toggle:checked + .nav-button span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked + .nav-button span:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
  }
</style>