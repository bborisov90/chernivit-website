---
const { title, description } = Astro.props;
---

<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="logo">Черни Вит</a>
      <nav>
        <a href="/za-cherni-vit">За Черни Вит</a>
        <a href="/mahali">Махали</a>
        <a href="/zabelezhitelnosti">Забележителности</a>
        <a href="/zeleno-sirene">Зелено сирене</a>
        <a href="/galeria">Галерия</a>
        <a href="/kontakti">Контакти</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <strong>Черни Вит</strong>
      <p>Официален обществен сайт в развитие.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --green: #1f4d3a;
    --dark: #13251d;
    --gold: #d6a756;
    --cream: #f8f5ef;
    --white: #ffffff;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--cream);
    color: var(--dark);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    width: 100%;
    padding: 18px 7vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--dark);
    color: var(--white);
  }

  .logo {
    color: var(--white);
    text-decoration: none;
    font-weight: 800;
    font-size: 1.25rem;
    white-space: nowrap;
  }

  nav {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  nav a {
    color: var(--white);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .page {
    padding: 90px 7vw;
    min-height: 70vh;
  }

  .eyebrow {
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 800;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    margin: 10px 0 24px;
  }

  .lead {
    max-width: 760px;
    font-size: 1.25rem;
    line-height: 1.7;
  }

  footer {
    padding: 50px 7vw;
    background: var(--dark);
    color: var(--white);
  }

  @media (max-width: 900px) {
    .site-header {
      align-items: flex-start;
      gap: 16px;
      flex-direction: column;
    }

    nav {
      justify-content: flex-start;
    }

    nav a {
      font-size: 0.85rem;
    }
  }
</style>