---
const { title, description } = Astro.props;
---

<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <header class="site-header">
      <a href="/" class="logo">Черни Вит</a>

      <button class="menu-button" aria-label="Отвори меню" aria-expanded="false">
        ☰
      </button>

      <nav class="site-nav">
        <a href="/za-cherni-vit">За Черни Вит</a>
        <a href="/mahali">Махали</a>
        <a href="/zabelezhitelnosti">Забележителности</a>
        <a href="/zeleno-sirene">Зелено сирене</a>
        <a href="/uchilishte">Училище</a>
        <a href="/galeria">Галерия</a>
        <a href="/novini">Новини</a>
        <a href="/kontakti">Контакти</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <strong>Черни Вит</strong>
      <p>Официален обществен сайт в развитие.</p>
    </footer>

    <script>
      const button = document.querySelector(".menu-button");
      const nav = document.querySelector(".site-nav");

      button?.addEventListener("click", () => {
        nav?.classList.toggle("is-open");

        const isOpen = nav?.classList.contains("is-open");
        button.setAttribute("aria-expanded", String(isOpen));
        button.textContent = isOpen ? "×" : "☰";
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --green: #1f4d3a;
    --dark: #13251d;
    --gold: #d6a756;
    --cream: #f8f5ef;
    --white: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--cream);
    color: var(--dark);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    width: 100%;
    padding: 18px 7vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--dark);
    color: var(--white);
  }

  .logo {
    color: var(--white);
    text-decoration: none;
    font-weight: 800;
    font-size: 1.25rem;
    white-space: nowrap;
  }

  .menu-button {
    display: none;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    background: transparent;
    color: var(--white);
    font-size: 1.7rem;
    line-height: 1;
    cursor: pointer;
  }

  .site-nav {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .site-nav a {
    color: var(--white);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .page {
    padding: 70px 7vw;
    min-height: 62vh;
  }

  .page h1 {
    font-size: clamp(2.3rem, 4.5vw, 4.2rem);
    line-height: 1.05;
    margin: 10px 0 24px;
    max-width: 900px;
  }

  .lead {
    max-width: 760px;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
  }

  .eyebrow {
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 800;
  }

  footer {
    padding: 50px 7vw;
    background: var(--dark);
    color: var(--white);
  }

  @media (max-width: 900px) {
    .site-header {
      align-items: center;
      flex-direction: row;
      gap: 16px;
    }

    .menu-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      padding: 16px 7vw 22px;
      background: var(--dark);
      flex-direction: column;
      gap: 14px;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .site-nav.is-open {
      display: flex;
    }

    .site-nav a {
      font-size: 1rem;
      padding: 6px 0;
    }

    .page {
      padding: 50px 7vw;
      min-height: 55vh;
    }

    .page h1 {
      font-size: clamp(2.1rem, 9vw, 3.1rem);
      line-height: 1.05;
    }
  }
</style>